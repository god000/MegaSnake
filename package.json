{
  "name": "megasnake",
  "version": "0.1.0",
  "private": true,
  "description": "MegaRace Chaos — browser multiplayer arcade snake (5 players, 3-minute matches)",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "dev": "npm-run-all -p dev:server dev:web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
